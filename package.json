{
  "name": "slimebot",
  "version": "0.1.0",
  "private": true,
  "description": "Matrix-hosted Codex agent",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:mcp-controller": "node dist/mcp/controllerMcpServer.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openai/codex": "^0.106.0",
    "js-yaml": "^4.1.1",
    "matrix-bot-sdk": "^0.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.3",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
